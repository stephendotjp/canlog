# Postgres connection string (Vercel Postgres / Neon / Supabase all work).
# Vercel projects expose this automatically once a Postgres store is linked.
DATABASE_URL="postgres://user:password@host:5432/canlog"

# Anthropic API key — used ONLY from server-side API routes, never the client.
ANTHROPIC_API_KEY="sk-ant-..."

# Vercel Blob token for storing scanned photos. Provisioned automatically on
# Vercel when a Blob store is linked. Leave unset locally to skip image storage
# (the app still works; entries just won't have a thumbnail).
BLOB_READ_WRITE_TOKEN=""
